eur photography style as if taken with a phone camera"],"color":"#232","bgcolor":"#353"},{"id":187,"type":"MarkdownNote","pos":[-1520,250],"size":[589.7745361328125,729.6222534179688],"flags":{"collapsed":false},"order":8,"mode":0,"inputs":[],"outputs":[],"title":"Pixaroma - Note - START HERE (Episode Nunchaku)","properties":{"ue_properties":{"widget_ue_connectable":{},"version":"7.3","input_ue_unconnectable":{}}},"widgets_values":["# !!! This workflow is made for COMFYUI-Nunchaku Version\n\n### Install this portable ComfyUI version into a different folder following the instructions from [HERE](https://github.com/Tavris1/ComfyUI-Easy-Install/tree/Windows-Nunchaku)\n\n# Works only with Nvidia Card and Windows\n\n---\n\n## 🟣 Nunchaku FLUX DiT Loader\n### Download svdq-int4_r32-flux.1-dev.safetensors from [HERE](https://huggingface.co/mit-han-lab/nunchaku-flux.1-dev/resolve/main/svdq-int4_r32-flux.1-dev.safetensors?download=true)\n\n📁 **Place in:** `ComfyUI/models/diffusion_models` \n\nMore Info about the model [HERE](https://huggingface.co/mit-han-lab/nunchaku-flux.1-dev/tree/main)\n\n---\n\n## 🟣 Nunchaku Text Encoder Loader V2\n\n###  Download clip_l.safetensors from [HERE](https://huggingface.co/comfyanonymous/flux_text_encoders/resolve/main/clip_l.safetensors?download=true)  \n\n📁 **Place in:** `ComfyUI/models/clip`  \n\n###  Download awq-int4-flux.1-t5xxl.safetensors from [HERE](https://huggingface.co/mit-han-lab/nunchaku-t5/resolve/main/awq-int4-flux.1-t5xxl.safetensors?download=true)\n\n📁 **Place in:** `ComfyUI/models/clip`\n\n---\n\n## 🟣 Load VAE\n\n### Download **ae.safetensor** vae model from [HERE](https://huggingface.co/Comfy-Org/Lumina_Image_2.0_Repackaged/resolve/main/split_files/vae/ae.safetensors?download=true)  \n\n📁 **Place in:** `ComfyUI/models/vae`  \n\n---\n\n## 🆙 Load Upscale Model  \n\n### Download 4x_NMKD-Siax_200k.pth mode from [HERE](https://huggingface.co/Akumetsu971/SD_Anime_Futuristic_Armor/resolve/main/4x_NMKD-Siax_200k.pth?download=true)  \n\n**Place in:** `ComfyUI/models/upscale_models`\n\n---\n\n## 📚 Resources  \n🎥 **Tutorials:** [Pixaroma YouTube Channel](https://www.youtube.com/@pixaroma)  \n💬 **Community Discord:** [Join Here](https://discord.com/invite/gggpkVgBf3)\n\nLearn more about Kontext model on [Comfy.org](https://docs.comfy.org/tutorials/flux/flux-1-kontext-dev) and [blf.ai](https://bfl.ai/models/flux-kontext)\n\nLearn how to prompt for Flux Kontext [HERE](https://docs.comfy.org/tutorials/flux/flux-1-kontext-dev#flux-kontext-prompt-techniques)\n\nLearn more about Nunchaku [HERE](https://github.com/mit-han-lab/ComfyUI-nunchaku)\n"],"color":"#432","bgcolor":"#653"},{"id":185,"type":"Label (rgthree)","pos":[-905.8787231445312,174.08111572265625],"size":[306.2744140625,25],"flags":{"allow_interaction":true},"order":9,"mode":0,"inputs":[],"outputs":[],"title":"Square | 2048x2048px | 1:1","properties":{"fontSize":25,"fontFamily":"Arial","fontColor":"#ffffff","textAlign":"center","backgroundColor":"transparent","padding":0,"borderRadius":0,"ue_properties":{"widget_ue_connectable":{},"version":"7.3","input_ue_unconnectable":{}}},"color":"#fff0","bgcolor":"#fff0"},{"id":188,"type":"NunchakuFluxDiTLoader","pos":[-910,260],"size":[399.7103576660156,202],"flags":{},"order":10,"mode":0,"inputs":[{"localized_name":"model_path","name":"model_path","type":"COMBO","widget":{"name":"model_path"},"link":null},{"localized_name":"cache_threshold","name":"cache_threshold","type":"FLOAT","widget":{"name":"cache_threshold"},"link":null},{"localized_name":"attention","name":"attention","type":"COMBO","widget":{"name":"attention"},"link":null},{"localized_name":"cpu_offload","name":"cpu_offload","type":"COMBO","widget":{"name":"cpu_offload"},"link":null},{"localized_name":"device_id","name":"device_id","type":"INT","widget":{"name":"device_id"},"link":null},{"localized_name":"data_type","name":"data_type","type":"COMBO","widget":{"name":"data_type"},"link":null},{"localized_name":"i2f_mode","name":"i2f_mode","sh