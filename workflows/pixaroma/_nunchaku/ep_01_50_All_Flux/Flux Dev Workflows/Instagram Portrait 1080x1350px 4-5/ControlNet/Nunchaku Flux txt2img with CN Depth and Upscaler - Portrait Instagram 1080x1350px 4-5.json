ile_batch_size` | Tiles processed at once. Higher = faster, but uses more VRAM.               |\n|                   | 🔹 1–2 = safe and clean                                                      |\n|                   | 🔹 4–6 = fast on 24GB GPUs (like RTX 4090)                                   |\n\n💡 Tips:\n- Use **square tiles** (width = height)\n- Match **overlap** to tile size to avoid seams\n- 768 is often the sweet spot for quality + speed\n- 1024 tiles may generate more detail, but also more \"creative noise\"\n"],"color":"#323","bgcolor":"#535"},{"id":170,"type":"SaveImage","pos":[1254.65380859375,527.3526611328125],"size":[426.2710266113281,590.759765625],"flags":{},"order":33,"mode":2,"inputs":[{"localized_name":"images","name":"images","type":"IMAGE","link":229},{"localized_name":"filename_prefix","name":"filename_prefix","type":"STRING","widget":{"name":"filename_prefix"},"link":null}],"outputs":[],"title":"Save Image UPSCALED","properties":{"cnr_id":"comfy-core","ver":"0.3.27","Node name for S&R":"SaveImage","ue_properties":{"widget_ue_connectable":{},"version":"7.3","input_ue_unconnectable":{}}},"widgets_values":["UP"]},{"id":196,"type":"SaveImage","pos":[1706.58447265625,527.3526611328125],"size":[426.2710266113281,590.759765625],"flags":{},"order":35,"mode":2,"inputs":[{"localized_name":"images","name":"images","type":"IMAGE","link":230},{"localized_name":"filename_prefix","name":"filename_prefix","type":"STRING","widget":{"name":"filename_prefix"},"link":null}],"outputs":[],"title":"Save Image Instagram Portrait 1080x1350px","properties":{"cnr_id":"comfy-core","ver":"0.3.27","Node name for S&R":"SaveImage","ue_properties":{"widget_ue_connectable":{},"version":"7.3","input_ue_unconnectable":{}}},"widgets_values":["Insta"]},{"id":51,"type":"KSampler","pos":[914.8056030273438,495.7776184082031],"size":[315,262],"flags":{},"order":30,"mode":2,"inputs":[{"localized_name":"model","name":"model","type":"MODEL","link":180},{"localized_name":"positive","name